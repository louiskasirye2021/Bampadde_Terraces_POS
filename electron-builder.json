{
  "appId": "com.bampadde.terraces.pos",
  "productName": "Bampadde Terraces POS",
  "directories": {
    "buildResources": "assets",
    "output": "dist"
  },
  "files": [
    "build/**/*",
    "electron.js",
    "preload.js",
    "package.json",
    "node_modules/**/*"
  ],
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": [
          "x64"
        ]
      }
    ],
    "sign": null
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "Bampadde Terraces POS"
  },
  "portable": {
    "artifactName": "${productName}-${version}.exe"
  },
  "mac": {
    "target": [
      "dmg",
      "zip"
    ],
    "category": "public.app-category.business"
  },
  "linux": {
    "target": [
      "AppImage",
      "deb"
    ],
    "category": "Office"
  }
}
